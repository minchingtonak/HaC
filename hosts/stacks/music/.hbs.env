PUID=0
PGID=0

LIDARR_API=your-lidarr-api-key

DOWNLOADS_PATH=/mnt/media/downloads        # Host path for downloads
MUSIC_VALIDATED_PATH=/mnt/media/           # Host path for beets inbox
MUSIC_LIBRARY_PATH=/mnt/media/music        # Host path for final library

LIDARR_CONFIG_PATH=/docker/music/lidarr    # Host path for lidarr config
CUSTOM_SCRIPTS_PATH=./config/scripts       # Host path for post-import.sh

SLSKD_DATA_PATH=/docker/music/slskd

BEETS_CONFIG_DIR=/docker/music/beets-flask
BEETS_CONFIG_PATH=./config/beets-flask/config.yaml   # Host path for beets config
BEETS_REQ_PATH=./config/beets-flask/config.yaml   # Host path for beets config
BEETS_LOGS_PATH=/docker/music/beets-flask            # Host path for beets logs
